{
	"name": "vscode-readme-hello-world",
	"displayName": "Hello World (education sample)",
	"description": "Minimal VS Code extension aligned with the VSCode_Readme learning path (extensions + Extension API).",
	"version": "0.0.1",
	"publisher": "local-education",
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "https://github.com/aadorian/VSCode_Readme"
	},
	"engines": {
		"vscode": "^1.85.0"
	},
	"categories": [
		"Other"
	],
	"activationEvents": [
		"onCommand:helloWorld.sayHello"
	],
	"main": "./out/extension.js",
	"contributes": {
		"commands": [
			{
				"command": "helloWorld.sayHello",
				"title": "Hello World: Say Hello"
			}
		]
	},
	"scripts": {
		"compile": "tsc -p ./",
		"watch": "tsc -watch -p ./",
		"vscode:prepublish": "npm run compile"
	},
	"devDependencies": {
		"@types/node": "^20.14.0",
		"@types/vscode": "^1.85.0",
		"typescript": "^5.6.0"
	}
}
